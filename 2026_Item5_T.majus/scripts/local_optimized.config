// local_plant.config - 针对 230Mb 小基因组优化
// local_plant_small.config - 针对小基因组实现的极致并行配置

executor {
    name = 'local'
    cpus = 32
    memory = '90 GB'
}

process {
    // 针对 232Mb 基因组，内存占用极低
    withName: 'STAR_ALIGN' {
        cpus = 4           // 每个样本分配 4 个物理核心
        maxForks = 8       // 物理核心 (4) * 并行数 (8) = 32 核心 (满载)
        // 预估内存总占用: 8 并行 * 5GB (Index+Buffer) = 40GB (安全)
    }

    withName: 'SALMON_QUANT' {
        cpus = 4
        maxForks = 8
    }

    // 其他轻量级任务可以更高并发
    withName: 'FASTQC|TRIMGALORE' {
        cpus = 2
        maxForks = 16
    }
}