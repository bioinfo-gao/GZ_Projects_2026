// local_plant_small.config - 稳健极速平衡版

executor {
    name = 'local'
    cpus = 32
    memory = '90 GB'
}

process {
    // 针对 STAR 的内存尖峰，将并发下调至 5
    withName: 'STAR_ALIGN|PICARD_MARKDUPLICATES' {
        cpus   = 6               // 每个任务增加到 6 核 (5任务 * 6 = 30核)
        memory = '16 GB'         // 每个任务申报 16GB (5任务 * 16 = 80GB，安全)
        maxForks = 5             // 并发数下调至 5，确保稳定性
    }

    withLabel: 'process_high' {
        cpus   = 6
        memory = '16 GB'
        maxForks = 5
    }

    withName: 'SALMON_QUANT' {
        cpus   = 4
        maxForks = 8
    }

    withLabel: 'process_medium' {
        cpus   = 2
        maxForks = 15
    }
}